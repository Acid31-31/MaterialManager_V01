## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017 cache/options directory
.vs/

# Visual Studio Code
.vscode/

# ReSharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# NuGet Packages
*.nupkg
*.snupkg
**/packages/*
!**/packages/build/
*.nuget.props
*.nuget.targets

# Build output specific
USB_Package/
*.dll
*.exe
*.pdb

# Backup files
*_Backup_*/
*.bak
*.old

# Database files (falls vorhanden)
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# OS files
Thumbs.db
Desktop.ini
.DS_Store

# Test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# Publish Profiles (können sensible Daten enthalten)
*.pubxml
*.publishproj

# License keys and sensitive data
*.lic
*.license
license_keys/
LicenseKeys/

# Temporäre Excel-Dateien
~$*.xlsx
~$*.xls

# Explicit safety ignores for local artifacts
BACKUP_*/
Backups/
*.zip
*.tmp
*.log
USB_Installation/**/startup_log.txt
USB_Installation/**/startup_*.txt

# Additional explicit ignores (requested)
**/bin/
**/obj/
*.Backup.tmp
*.csproj.Backup.tmp

# Track release automation scripts
!Tools/
!Tools/Release/
!Tools/Release/*.ps1

# MSI/Release artifacts
/dist/
*.msi
Installer_Source/**/Release/*.msi
Installer_Source/**/Debug/*.msi
