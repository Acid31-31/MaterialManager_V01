<Window x:Class="MaterialManagerInstaller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MaterialManager V01 - Setup"
        Width="700" Height="520"
        MinWidth="700" MinHeight="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundDarkBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        WindowStyle="SingleBorderWindow"
        Icon="{x:Null}">

    <Window.Resources>
        <!-- Separator Line -->
        <Style x:Key="SeparatorLineStyle" TargetType="Rectangle">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Fill" Value="{StaticResource SurfaceDark2Brush}"/>
            <Setter Property="Margin" Value="0,0,0,0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Left Sidebar -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar Background -->
        <Border Grid.Column="0"
                Background="{StaticResource SurfaceDark1Brush}">
            <StackPanel VerticalAlignment="Top" Margin="0,30,0,0">

                <!-- Logo Area -->
                <Border Width="70" Height="70"
                        Background="{StaticResource AccentGreenBrush}"
                        CornerRadius="12"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,20">
                    <TextBlock Text="M"
                               FontSize="40"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- App Name in Sidebar -->
                <TextBlock Text="MaterialManager"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource AccentGreenBrush}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"/>
                <TextBlock Text="V01"
                           FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,2,0,30"/>

                <!-- Step Indicators -->
                <StackPanel x:Name="StepPanel" Margin="20,0,0,0">

                    <!-- Step 1 -->
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                        <Border x:Name="Step1Indicator"
                                Width="24" Height="24"
                                Background="{StaticResource AccentGreenBrush}"
                                CornerRadius="12">
                            <TextBlock x:Name="Step1Number" Text="1"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock x:Name="Step1Label"
                                   Text="Willkommen"
                                   FontSize="12"
                                   Foreground="{StaticResource AccentGreenBrush}"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0"/>
                    </StackPanel>

                    <!-- Step 2 -->
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                        <Border x:Name="Step2Indicator"
                                Width="24" Height="24"
                                Background="{StaticResource SurfaceDark3Brush}"
                                CornerRadius="12">
                            <TextBlock x:Name="Step2Number" Text="2"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock x:Name="Step2Label"
                                   Text="Lizenz"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0"/>
                    </StackPanel>

                    <!-- Step 3 -->
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                        <Border x:Name="Step3Indicator"
                                Width="24" Height="24"
                                Background="{StaticResource SurfaceDark3Brush}"
                                CornerRadius="12">
                            <TextBlock x:Name="Step3Number" Text="3"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock x:Name="Step3Label"
                                   Text="Zielverzeichnis"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0"/>
                    </StackPanel>

                    <!-- Step 4 -->
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                        <Border x:Name="Step4Indicator"
                                Width="24" Height="24"
                                Background="{StaticResource SurfaceDark3Brush}"
                                CornerRadius="12">
                            <TextBlock x:Name="Step4Number" Text="4"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock x:Name="Step4Label"
                                   Text="Installation"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0"/>
                    </StackPanel>

                    <!-- Step 5 -->
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                        <Border x:Name="Step5Indicator"
                                Width="24" Height="24"
                                Background="{StaticResource SurfaceDark3Brush}"
                                CornerRadius="12">
                            <TextBlock x:Name="Step5Number" Text="5"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock x:Name="Step5Label"
                                   Text="Abschluss"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Version Info at bottom -->
                <TextBlock Text="Version 1.0.6"
                           FontSize="10"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Bottom"
                           Margin="0,40,0,10"/>
                <TextBlock Text="Hersteller: Hölzer"
                           FontSize="10"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>
            </StackPanel>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Content Panels -->
            <Grid Grid.Row="0" Margin="30,30,30,20">

                <!-- ======================== SCREEN 1: Welcome ======================== -->
                <StackPanel x:Name="Screen1" Visibility="Visible">

                    <TextBlock Text="Willkommen"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="{StaticResource AccentGreenBrush}"
                               Margin="0,0,0,8"/>

                    <TextBlock Text="MaterialManager V01"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,6"/>

                    <TextBlock Text="Professionelle Material- und Bestandsverwaltung für Industriebetriebe"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,24"/>

                    <!-- Info Card -->
                    <Border Background="{StaticResource SurfaceDark1Brush}"
                            CornerRadius="8"
                            Padding="20"
                            Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Dieses Setup-Programm installiert:"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,0,0,12"/>

                            <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                                <TextBlock Text="✓" Foreground="{StaticResource AccentGreenBrush}" FontSize="13" Width="20"/>
                                <TextBlock Text="MaterialManager V01 Hauptanwendung"
                                           FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                                <TextBlock Text="✓" Foreground="{StaticResource AccentGreenBrush}" FontSize="13" Width="20"/>
                                <TextBlock Text="Desktop- und Startmenü-Verknüpfungen"
                                           FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                                <TextBlock Text="✓" Foreground="{StaticResource AccentGreenBrush}" FontSize="13" Width="20"/>
                                <TextBlock Text="Alle erforderlichen Komponenten und Bibliotheken"
                                           FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                                <TextBlock Text="✓" Foreground="{StaticResource AccentGreenBrush}" FontSize="13" Width="20"/>
                                <TextBlock Text="Automatische Konfiguration"
                                           FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Es wird empfohlen, alle anderen Anwendungen zu schließen, bevor Sie mit der Installation fortfahren."
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <!-- ======================== SCREEN 2: License ======================== -->
                <StackPanel x:Name="Screen2" Visibility="Collapsed">

                    <TextBlock Text="Lizenzvereinbarung"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="{StaticResource AccentGreenBrush}"
                               Margin="0,0,0,8"/>

                    <TextBlock Text="Bitte lesen Sie die folgende Lizenzvereinbarung sorgfältig durch."
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,16"/>

                    <!-- License Text Box -->
                    <Border Background="{StaticResource SurfaceDark1Brush}"
                            BorderBrush="{StaticResource SurfaceDark3Brush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Height="280">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Padding="2">
                            <TextBox x:Name="LicenseTextBox"
                                     Background="Transparent"
                                     Foreground="{StaticResource TextSecondaryBrush}"
                                     BorderThickness="0"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     FontSize="11.5"
                                     FontFamily="Consolas"
                                     Padding="12"
                                     VerticalScrollBarVisibility="Disabled"/>
                        </ScrollViewer>
                    </Border>

                    <!-- Accept Checkbox -->
                    <CheckBox x:Name="LicenseAcceptCheckBox"
                              Style="{StaticResource DarkCheckBoxStyle}"
                              Content="Ich akzeptiere die Bedingungen der Lizenzvereinbarung"
                              Margin="0,16,0,0"
                              FontSize="13"
                              Checked="LicenseAcceptCheckBox_Changed"
                              Unchecked="LicenseAcceptCheckBox_Changed"/>
                </StackPanel>

                <!-- ======================== SCREEN 3: Install Path ======================== -->
                <StackPanel x:Name="Screen3" Visibility="Collapsed">

                    <TextBlock Text="Installationsziel"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="{StaticResource AccentGreenBrush}"
                               Margin="0,0,0,8"/>

                    <TextBlock Text="Wählen Sie das Verzeichnis, in dem MaterialManager V01 installiert werden soll."
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,20"/>

                    <!-- Path Input -->
                    <TextBlock Text="Installationsverzeichnis:"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,6"/>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="InstallPathTextBox"
                                 Grid.Column="0"
                                 Style="{StaticResource DarkTextBoxStyle}"
                                 Text="C:\Program Files\MaterialManager_V01\"
                                 Margin="0,0,8,0"/>
                        <Button Grid.Column="1"
                                Content="Durchsuchen..."
                                Style="{StaticResource GrayButtonStyle}"
                                Padding="12,6"
                                FontSize="12"
                                Click="BrowseButton_Click"/>
                    </Grid>

                    <!-- Disk Space Info -->
                    <Border Background="{StaticResource SurfaceDark1Brush}"
                            CornerRadius="6"
                            Padding="16"
                            Margin="0,0,0,20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Benötigter Speicherplatz"
                                           FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Text="~250 MB"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Verfügbarer Speicherplatz"
                                           FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock x:Name="AvailableSpaceText"
                                           Text="Wird ermittelt..."
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentGreenBrush}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Options -->
                    <TextBlock Text="Installationsoptionen:"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,10"/>

                    <CheckBox x:Name="DesktopShortcutCheckBox"
                              Style="{StaticResource DarkCheckBoxStyle}"
                              Content="Desktop-Verknüpfung erstellen"
                              IsChecked="True"
                              Margin="0,0,0,8"/>

                    <CheckBox x:Name="StartMenuCheckBox"
                              Style="{StaticResource DarkCheckBoxStyle}"
                              Content="Start-Menü Einträge erstellen"
                              IsChecked="True"
                              Margin="0,0,0,0"/>
                </StackPanel>

                <!-- ======================== SCREEN 4: Progress ======================== -->
                <StackPanel x:Name="Screen4" Visibility="Collapsed">

                    <TextBlock Text="Installation wird durchgeführt..."
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{StaticResource AccentGreenBrush}"
                               Margin="0,0,0,24"
                               TextWrapping="Wrap"/>

                    <!-- Status Label -->
                    <TextBlock x:Name="StatusLabel"
                               Text="Vorbereitung..."
                               FontSize="13"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,12"
                               TextWrapping="Wrap"/>

                    <!-- Progress Bar -->
                    <Grid Margin="0,0,0,8">
                        <ProgressBar x:Name="InstallProgressBar"
                                     Style="{StaticResource GreenProgressBarStyle}"
                                     Height="12"
                                     Value="0"
                                     Maximum="100"/>
                    </Grid>

                    <!-- Percentage -->
                    <TextBlock x:Name="PercentageLabel"
                               Text="0%"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource AccentGreenBrush}"
                               HorizontalAlignment="Right"
                               Margin="0,0,0,20"/>

                    <!-- File being copied -->
                    <Border Background="{StaticResource SurfaceDark1Brush}"
                            CornerRadius="6"
                            Padding="16"
                            Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Aktuelle Datei:"
                                       FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,0,4"/>
                            <TextBlock x:Name="CurrentFileLabel"
                                       Text=""
                                       FontSize="12"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       TextWrapping="Wrap"
                                       FontFamily="Consolas"/>
                        </StackPanel>
                    </Border>

                    <!-- Log Output -->
                    <Border Background="{StaticResource SurfaceDark1Brush}"
                            BorderBrush="{StaticResource SurfaceDark3Brush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Height="160">
                        <ScrollViewer x:Name="LogScrollViewer"
                                      VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="LogTextBlock"
                                       FontSize="11"
                                       FontFamily="Consolas"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Padding="12"
                                       TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </Border>
                </StackPanel>

                <!-- ======================== SCREEN 5: Complete ======================== -->
                <StackPanel x:Name="Screen5" Visibility="Collapsed">

                    <!-- Success Icon -->
                    <Border Width="80" Height="80"
                            Background="{StaticResource AccentGreenBrush}"
                            CornerRadius="16"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,20">
                        <TextBlock Text="M"
                                   FontSize="44"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="Installation abgeschlossen! ✅"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{StaticResource AccentGreenBrush}"
                               Margin="0,0,0,12"
                               TextWrapping="Wrap"/>

                    <TextBlock x:Name="CompletionPathLabel"
                               Text=""
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,20"/>

                    <!-- Results Card -->
                    <Border Background="{StaticResource SurfaceDark1Brush}"
                            CornerRadius="8"
                            Padding="20"
                            Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Folgendes wurde erfolgreich installiert:"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,0,0,12"/>

                            <TextBlock x:Name="DesktopShortcutResult"
                                       Text="✅ Desktop-Verknüpfung erstellt"
                                       FontSize="13"
                                       Foreground="{StaticResource AccentGreenBrush}"
                                       Margin="0,4,0,4"/>

                            <TextBlock x:Name="StartMenuResult"
                                       Text="✅ Start-Menü Einträge erstellt"
                                       FontSize="13"
                                       Foreground="{StaticResource AccentGreenBrush}"
                                       Margin="0,4,0,4"/>

                            <TextBlock Text="✅ Programmdateien kopiert"
                                       FontSize="13"
                                       Foreground="{StaticResource AccentGreenBrush}"
                                       Margin="0,4,0,4"/>
                        </StackPanel>
                    </Border>

                    <!-- Launch Checkbox -->
                    <CheckBox x:Name="LaunchAppCheckBox"
                              Style="{StaticResource DarkCheckBoxStyle}"
                              Content="MaterialManager V01 jetzt starten"
                              IsChecked="True"
                              FontSize="13"/>
                </StackPanel>

            </Grid>

            <!-- Bottom Navigation Bar -->
            <Border Grid.Row="1"
                    Background="{StaticResource SurfaceDark1Brush}"
                    Padding="30,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Cancel / Back buttons -->
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal">
                        <Button x:Name="CancelButton"
                                Content="Abbrechen"
                                Style="{StaticResource GrayButtonStyle}"
                                Padding="16,8"
                                FontSize="13"
                                Click="CancelButton_Click"/>
                    </StackPanel>

                    <!-- Back / Next / Finish buttons -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal">
                        <Button x:Name="BackButton"
                                Content="← Zurück"
                                Style="{StaticResource GrayButtonStyle}"
                                Padding="16,8"
                                FontSize="13"
                                IsEnabled="False"
                                Click="BackButton_Click"
                                Margin="0,0,10,0"/>

                        <Button x:Name="NextButton"
                                Content="Weiter →"
                                Style="{StaticResource GreenButtonStyle}"
                                Padding="20,8"
                                FontSize="13"
                                Click="NextButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
