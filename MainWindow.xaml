<Window x:Class="MaterialManager_V01.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:MaterialManager_V01.Converters"
        Title="MaterialManager V01" Height="800" Width="1600" Background="#0B0B0B"
        WindowState="Maximized">
    <Window.Resources>
        <conv:PercentToBrushConverter x:Key="PctToBrush"/>
        
        <!-- MENU & MENUITEM COMPLETE DARK THEME -->
        <Style TargetType="Menu">
            <Setter Property="Background" Value="#0F0F0F"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        
        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" BorderThickness="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="Icon"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="Shortcut"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <ContentPresenter Grid.Column="0" ContentSource="Icon" Margin="4,0,6,0" VerticalAlignment="Center"/>
                                <ContentPresenter Grid.Column="1" ContentSource="Header" RecognizesAccessKey="True" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="{TemplateBinding InputGestureText}" Margin="20,0,6,0" VerticalAlignment="Center" Foreground="#888"/>
                                <Path Grid.Column="3" x:Name="ArrowPath" Margin="4,0,0,0" VerticalAlignment="Center" Fill="White" Data="M 0 0 L 4 4 L 0 8 Z" Visibility="Collapsed"/>
                                
                                <Popup x:Name="PART_Popup" IsOpen="{TemplateBinding IsSubmenuOpen}" Placement="Right" AllowsTransparency="True" Focusable="False" PopupAnimation="Fade" VerticalOffset="-3">
                                    <Border Background="#1A1A1A" BorderBrush="#333" BorderThickness="1" Padding="2">
                                        <ScrollViewer CanContentScroll="True" MaxHeight="400">
                                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle"/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Role" Value="TopLevelHeader">
                                <Setter TargetName="Border" Property="Background" Value="#0F0F0F"/>
                                <Setter TargetName="PART_Popup" Property="Placement" Value="Bottom"/>
                            </Trigger>
                            <Trigger Property="Role" Value="TopLevelItem">
                                <Setter TargetName="Border" Property="Background" Value="#0F0F0F"/>
                            </Trigger>
                            <Trigger Property="Role" Value="SubmenuHeader">
                                <Setter TargetName="ArrowPath" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1976D2"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#666"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style TargetType="Separator">
            <Setter Property="Background" Value="#333"/>
            <Setter Property="Height" Value="1"/>
            <Setter Property="Margin" Value="4,2"/>
        </Style>
        
        <!-- COMBOBOX COMPLETE DARK THEME -->
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#222"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="3">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0" Content="{TemplateBinding SelectionBoxItem}" Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                                    <Path Grid.Column="1" Data="M 0 0 L 4 4 L 8 0 Z" Fill="White" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup" IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" AllowsTransparency="True">
                                <Border Background="#1A1A1A" BorderBrush="#444" BorderThickness="1" MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1976D2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- DATAGRID STYLES -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#121212"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="RowBackground" Value="#1A1A1A"/>
            <Setter Property="AlternatingRowBackground" Value="#151515"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="BorderBrush" Value="#333"/>
        </Style>
        
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>
        
        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                    <Setter Property="Background" Value="#1B5E20"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    <DockPanel>
        <Menu DockPanel.Dock="Top" Height="22" FontSize="15">
            <MenuItem Header="Datei">
                <MenuItem Header="Material neu" Click="OnMaterialNeu"/>
                <Separator/>
                <MenuItem Header="Import" Click="OnImport"/>
                <MenuItem Header="Export" Click="OnExport"/>
                <Separator/>
                <MenuItem Header="Netzwerk‑Einstellungen" Click="OnNetzwerkEinstellungen"/>
                <Separator/>
                <MenuItem Header="Beenden" Click="OnBeenden"/>
            </MenuItem>
            <MenuItem Header="Bearbeiten">
                <MenuItem Header="↶ Rückgängig (Ctrl+Z)" Click="OnUndo"/>
                <MenuItem Header="↷ Wiederherstellen" Click="OnRedo" IsEnabled="False"/>
                <Separator/>
                <MenuItem Header="Löschen" Click="OnMaterialLoeschen"/>
                <Separator/>
                <MenuItem Header="Tafel verbrauchen" Click="OnTafelVerbrauchen"/>
            </MenuItem>
            <MenuItem Header="Ansicht">
                <MenuItem Header="Inventur" Click="OnInventur"/>
                <MenuItem Header="Statistik" Click="OnStatistik"/>
                <MenuItem Header="Reste suchen" Click="OnResteSuchen"/>
                <MenuItem Header="🔖 Reservierte Reste" Click="OnReservierteReste"/>
            </MenuItem>
            <MenuItem Header="Hilfe">
                <MenuItem Header="📄 Materialliste drucken" Click="OnPrintMaterialList"/>
                <MenuItem Header="📊 Als Excel exportieren" Click="OnExportExcel"/>
                <MenuItem Header="📋 Als CSV exportieren" Click="OnExportCSV"/>
                <Separator/>
                <MenuItem Header="Lizenz aktivieren" Click="OnLizenzAktivieren"/>
                <MenuItem Header="Nach Updates suchen" Click="OnCheckForUpdates"/>
            </MenuItem>
        </Menu>
        
        <Border DockPanel.Dock="Top" Background="#1F1F1F" Height="65">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Image Grid.Column="0" Source="Assets/logo.png" Height="55" Margin="0,0,15,0"/>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,15,0">
                    <Button Content="↶" Click="OnUndo" Background="#333" Foreground="White" Padding="12,6" Margin="0,0,5,0" Cursor="Hand" ToolTip="Rückgängig (Ctrl+Z)"/>
                    <Button Content="↷" Click="OnRedo" Background="#333" Foreground="White" Padding="12,6" Margin="0,0,5,0" Cursor="Hand" ToolTip="Wiederherstellen (Ctrl+Y)"/>
                    <Separator Background="#555" Width="1" Margin="5,0"/>
                    <Button Content="🔄" Click="OnCheckForUpdates" Background="#333" Foreground="White" Padding="12,6" Margin="0,0,5,0" Cursor="Hand" ToolTip="Nach Programm-Updates suchen"/>
                </StackPanel>
                
                <DockPanel Grid.Column="2" VerticalAlignment="Center">
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <ComboBox x:Name="FormFilterBox" Width="100" Margin="0,0,8,0" SelectionChanged="OnFormFilterChanged">
                            <ComboBoxItem IsSelected="True">Alle</ComboBoxItem>
                            <ComboBoxItem>GF</ComboBoxItem>
                            <ComboBoxItem>MF</ComboBoxItem>
                            <ComboBoxItem>KF</ComboBoxItem>
                            <ComboBoxItem>Rest</ComboBoxItem>
                        </ComboBox>
                        <ComboBox x:Name="WeightModeBox" Width="100" Margin="0,0,8,0" SelectionChanged="OnWeightModeChanged">
                            <ComboBoxItem IsSelected="True">Gesamt</ComboBoxItem>
                            <ComboBoxItem>Gefiltert</ComboBoxItem>
                        </ComboBox>
                        <Button Content="🗑️ Löschen" Click="OnMaterialLoeschen" Background="#F44336" Foreground="White" Padding="10,5" Cursor="Hand"/>
                    </StackPanel>
                    <TextBox x:Name="SearchBox" Background="#222" Foreground="White" Padding="6,4" TextChanged="OnSearchTextChanged" VerticalContentAlignment="Center" Height="28" FontSize="13" Margin="0,0,10,0" Width="320"/>
                </DockPanel>
            </Grid>
        </Border>
        
        <Border DockPanel.Dock="Top" Background="#0E0E0E" Padding="8">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Border Background="#1E1E1E" CornerRadius="5" Padding="10" Margin="0,0,8,0" Width="140" Height="75" Cursor="Hand" MouseLeftButtonDown="OnMaterialNeu">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="➕" FontSize="32" Foreground="#4CAF50" HorizontalAlignment="Center"/>
                            <TextBlock Text="Material neu" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,5,0,0" FontSize="11"/>
                        </StackPanel>
                    </Border>
                    
                    <Border Background="#1E1E1E" CornerRadius="5" Padding="12" Margin="0,0,8,0" Width="200" Height="75">
                        <StackPanel>
                            <TextBlock Text="Gesamtgewicht" Foreground="White" FontWeight="Bold" FontSize="11"/>
                            <TextBlock Text="{Binding GesamtGewichtText}" Foreground="#4CAF50" FontSize="20" FontWeight="Bold" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    
                    <Border Background="#1E1E1E" CornerRadius="5" Padding="12" Margin="0,0,8,0" Width="200" Height="75" Cursor="Hand" MouseLeftButtonDown="OnRegalauslastungClick">
                        <StackPanel>
                            <TextBlock Text="Regalauslastung" Foreground="White" FontWeight="Bold" FontSize="11"/>
                            <ProgressBar Value="{Binding DurchschnittAuslastung}" Minimum="0" Maximum="100" Height="10" Margin="0,4,0,3" Background="#2A2A2A" Foreground="#00A651"/>
                            <TextBlock Text="{Binding AuslastungText}" Foreground="#AAA" FontSize="10" HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#1E1E1E" CornerRadius="5" Padding="12" Margin="0,0,8,0" Width="230" Height="75" Cursor="Hand" MouseLeftButtonDown="OnEuPaletteClick">
                        <StackPanel>
                            <TextBlock Text="EU Palette (Rest Material)" Foreground="White" FontWeight="Bold" FontSize="11"/>
                            <ProgressBar Value="{Binding EuPalettePct}" Minimum="0" Maximum="100" Height="10" Margin="0,4,0,3" Background="#2A2A2A" Foreground="#FF9800"/>
                            <TextBlock Text="{Binding EuPaletteDisplayText}" Foreground="#AAA" FontSize="10" HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Border>
                    
                    <Border Background="#1E1E1E" CornerRadius="5" Padding="12" Margin="0,0,8,0" Width="180" Height="75" Cursor="Hand" MouseLeftButtonDown="OnNiedrigeBestaendeClick">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="⚠️ Niedrige Bestände" Foreground="White" FontWeight="Bold" FontSize="11"/>
                            <TextBlock Text="{Binding NiedrigeBestaendeText}" Foreground="{Binding NiedrigeBestaendeFarbe}" FontSize="18" FontWeight="Bold" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    
                    <Border Background="#1E1E1E" CornerRadius="5" Padding="12" Margin="0,0,8,0" Width="180" Height="75" Cursor="Hand" MouseLeftButtonDown="OnReservierteReste">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="🔖 Reservierte Reste" Foreground="White" FontWeight="Bold" FontSize="11"/>
                            <TextBlock Text="{Binding ReservierteResteCount}" Foreground="#4CAF50" FontSize="18" FontWeight="Bold" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    
                    <Border Background="#1E1E1E" CornerRadius="5" Padding="10" Margin="0,0,8,0" Width="160" Height="85" Cursor="Hand" MouseLeftButtonDown="OnResteSuchen">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="🔍" FontSize="28" Foreground="#4CAF50" HorizontalAlignment="Center"/>
                            <TextBlock Text="Reste suchen" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,4,0,0" FontSize="12"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- ✅ ONLINE-BENUTZER ANZEIGE -->
                    <Border Background="#1E1E1E" CornerRadius="5" Padding="12" Margin="0,0,8,0" Width="220" Height="85" Cursor="Hand" MouseLeftButtonDown="OnOnlineUsersClick" x:Name="OnlineUsersBorder">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="👥 Online Jetzt" Foreground="White" FontWeight="Bold" FontSize="11"/>
                            <TextBlock x:Name="OnlineUsersDisplay" Text="👤 hoelz" Foreground="#4CAF50" FontSize="13" FontWeight="Bold" Margin="0,8,0,0" TextWrapping="Wrap" MaxHeight="60"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>
        
        <DataGrid x:Name="MaterialGrid" ItemsSource="{Binding Materialien}" AutoGenerateColumns="False" Margin="10" CanUserAddRows="False" MouseDoubleClick="OnMaterialBearbeiten" RowHeight="32">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="" Width="35">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <CheckBox HorizontalAlignment="Center" Checked="OnSelectAllChecked" Unchecked="OnSelectAllUnchecked"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" Click="CheckBox_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Material" Binding="{Binding MaterialArt}" Width="90" IsReadOnly="True"/>
                <DataGridTextColumn Header="Legierung" Binding="{Binding Legierung}" Width="90" IsReadOnly="True"/>
                <DataGridTextColumn Header="Oberfläche" Binding="{Binding Oberflaeche}" Width="120" IsReadOnly="True"/>
                <DataGridTextColumn Header="Güte" Binding="{Binding Guete}" Width="70" IsReadOnly="True"/>
                <DataGridTextColumn Header="Form" Binding="{Binding Form}" Width="60" IsReadOnly="True"/>
                <DataGridTextColumn Header="Stärke" Binding="{Binding Staerke, StringFormat={}{0:0.0} mm}" Width="70" IsReadOnly="True"/>
                <DataGridTextColumn Header="Maß" Binding="{Binding Mass}" Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="Stück" Binding="{Binding Stueckzahl}" Width="50" IsReadOnly="True"/>
                <DataGridTextColumn Header="Gewicht (kg)" Binding="{Binding GewichtKg, StringFormat={}{0:0.00} kg}" Width="90" IsReadOnly="True"/>
                <DataGridTextColumn Header="Lagerort" Binding="{Binding Lagerort}" Width="90" IsReadOnly="True"/>
                <DataGridTextColumn Header="Restnummer" Binding="{Binding Restnummer}" Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="Datum" Binding="{Binding Datum, StringFormat=dd.MM.yyyy}" Width="90" IsReadOnly="True"/>
                <DataGridTextColumn Header="Geändert" Binding="{Binding AenderungsDatum, StringFormat=dd.MM.yyyy}" Width="90" IsReadOnly="True"/>
                <DataGridTextColumn Header="Angelegt von" Binding="{Binding AngelegtVon}" Width="110" IsReadOnly="True"/>
                <DataGridTextColumn Header="Geändert von" Binding="{Binding GeaendertVon}" Width="110" IsReadOnly="True"/>
                <DataGridTextColumn Header="Auftrag" Binding="{Binding AuftragNr}" Width="130" IsReadOnly="True"/>
                <DataGridTextColumn Header="Lieferant" Binding="{Binding Lieferant}" Width="90" IsReadOnly="True"/>
                <DataGridTextColumn Header="Lieferschein-Nr" Binding="{Binding LieferscheinNr}" Width="110" IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>
        
        <!-- ✅ EXPANDABLES ONLINE-USERS POPUP -->
        <Popup x:Name="OnlineUsersPopup" IsOpen="False" Placement="Mouse" AllowsTransparency="True" PopupAnimation="Fade">
            <Border Background="#1E1E1E" BorderBrush="#4CAF50" BorderThickness="2" CornerRadius="8" Padding="15" Width="280">
                <StackPanel>
                    <TextBlock Text="👥 Online Benutzer" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,0,0,12"/>
                    <ScrollViewer MaxHeight="300" VerticalScrollBarVisibility="Auto">
                        <ListBox x:Name="OnlineUsersList" Background="Transparent" BorderThickness="0" Foreground="White">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#4CAF50" FontSize="12" Margin="0,5,0,5"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>
                    <TextBlock Text="(Klick irgendwo zum Schließen)" Foreground="#888" FontSize="9" Margin="0,10,0,0" FontStyle="Italic"/>
                </StackPanel>
            </Border>
        </Popup>
    </DockPanel>
</Window>

