<Window x:Class="MaterialManager_V01.Views.ReservierteResteDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🔖 Reservierte Reste" Height="600" Width="1200" Background="#0B0B0B" WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#121212"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="RowBackground" Value="#1A1A1A"/>
            <Setter Property="AlternatingRowBackground" Value="#151515"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="BorderBrush" Value="#333"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#1F1F1F" Padding="15">
            <StackPanel>
                <TextBlock Text="🔖 Reservierte Reste" FontSize="20" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Materialien die für Aufträge reserviert sind" Foreground="#888" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>
        
        <Border DockPanel.Dock="Bottom" Background="#1F1F1F" Padding="10">
            <Button Content="Schließen" Click="OnSchliessen" Width="100" Background="#1976D2" Foreground="White" Padding="8"/>
        </Border>
        
        <DataGrid ItemsSource="{Binding ReservierteReste}" AutoGenerateColumns="False" Margin="10" IsReadOnly="True" Background="#121212" Foreground="White">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Material" Binding="{Binding MaterialArt}" Width="100"/>
                <DataGridTextColumn Header="Legierung" Binding="{Binding Legierung}" Width="100"/>
                <DataGridTextColumn Header="Form" Binding="{Binding Form}" Width="70"/>
                <DataGridTextColumn Header="Stärke" Binding="{Binding Staerke, StringFormat={}{0:0.0} mm}" Width="80"/>
                <DataGridTextColumn Header="Maß" Binding="{Binding Mass}" Width="120"/>
                <DataGridTextColumn Header="Stück" Binding="{Binding Stueckzahl}" Width="60"/>
                <DataGridTextColumn Header="Gewicht (kg)" Binding="{Binding GewichtKg}" Width="100"/>
                <DataGridTextColumn Header="Restnummer" Binding="{Binding Restnummer}" Width="120"/>
                <DataGridTextColumn Header="🎯 Auftrag" Binding="{Binding AuftragNr}" Width="200"/>
                <DataGridTextColumn Header="Reserviert von" Binding="{Binding GeaendertVon}" Width="120"/>
                <DataGridTextColumn Header="Geändert" Binding="{Binding AenderungsDatum, StringFormat=dd.MM.yyyy}" Width="90"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
