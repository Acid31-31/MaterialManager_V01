<Window x:Class="MaterialManager_V01.Views.ResteSucheErgebnisDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="✅ Gefundene Reste" Height="600" Width="1200" Background="#0B0B0B" WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A2A2A"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1976D2"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Gefundene Materialien - Material auswählen:" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
        <DataGrid Grid.Row="1" x:Name="ErgebnisGrid" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" Margin="0,0,0,10" SelectionUnit="FullRow" SelectionMode="Single" MouseDoubleClick="OnMaterialDoppelklick" Background="#121212" Foreground="White">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Material" Binding="{Binding MaterialArt}" Width="90"/>
                <DataGridTextColumn Header="Legierung" Binding="{Binding Legierung}" Width="90"/>
                <DataGridTextColumn Header="Stärke (mm)" Binding="{Binding Staerke}" Width="90"/>
                <DataGridTextColumn Header="Maß" Binding="{Binding Mass}" Width="100"/>
                <DataGridTextColumn Header="Stück" Binding="{Binding Stueckzahl}" Width="60"/>
                <DataGridTextColumn Header="Gewicht (kg)" Binding="{Binding GewichtKg}" Width="100"/>
                <DataGridTextColumn Header="Lagerort" Binding="{Binding Lagerort}" Width="100"/>
                <DataGridTextColumn Header="Form" Binding="{Binding Form}" Width="60"/>
            </DataGrid.Columns>
        </DataGrid>
        <Border Grid.Row="2" Background="#1E1E1E" Padding="15" CornerRadius="5" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="Auftragsnummer eingeben:" Foreground="White" FontSize="14" FontWeight="Bold"/>
                <TextBox x:Name="AuftragsnummerBox" Margin="0,8,0,0" FontSize="14" Background="#222" Foreground="White" Padding="8" Height="32"/>
            </StackPanel>
        </Border>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="✅ Reservieren" Click="OnReservieren" Width="150" Background="#1976D2" Foreground="White" Padding="16,8" Margin="8" Cursor="Hand"/>
            <Button Content="Abbrechen" Click="OnAbbrechen" Width="120" Background="#555" Foreground="White" Padding="16,8" Margin="8" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
