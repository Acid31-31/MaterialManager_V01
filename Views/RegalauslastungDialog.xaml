<Window x:Class="MaterialManager_V01.Views.RegalauslastungDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📦 Regalauslastung im Detail" 
        Height="650" Width="800" 
        Background="#0B0B0B"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        
        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="22"/>
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="100"/>
        </Style>
    </Window.Resources>
    
    <Border Background="#1A1A1A" Padding="25" CornerRadius="8">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top" Text="📦 Regalauslastung - Übersicht" 
                       FontSize="22" FontWeight="Bold" Foreground="White" 
                       Margin="0,0,0,20" HorizontalAlignment="Center"/>
            
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                <Button Content="Aktualisieren" Click="OnRefresh" Width="120" Height="35" 
                        Background="#1976D2" Foreground="White" FontSize="14" Cursor="Hand" Margin="0,0,10,0"/>
                <Button Content="Schließen" Click="OnClose" Width="120" Height="35" 
                        Background="#333" Foreground="White" FontSize="14" Cursor="Hand"/>
            </StackPanel>
            
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="RegalPanel">
                    <!-- Regale werden dynamisch hinzugefügt -->
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
