<Window x:Class="MaterialManager_V01.Views.ResteAuswahlDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reste auswählen" Height="500" Width="900" Background="#0B0B0B" WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style TargetType="DataGrid">
            <Setter Property="RowBackground" Value="#151515" />
            <Setter Property="AlternatingRowBackground" Value="#121212" />
            <Setter Property="GridLinesVisibility" Value="None" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="BorderBrush" Value="#222" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#121212" />
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1E1E1E" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="BorderBrush" Value="#333" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#1976D2" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="6" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Resources>
    <DockPanel Margin="10">
        <TextBlock DockPanel.Dock="Top" Text="Gefundene Reste auswählen" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,10" />
        <DataGrid x:Name="ResteGrid" AutoGenerateColumns="False" IsReadOnly="True" MouseDoubleClick="OnDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Material" Binding="{Binding MaterialArt}" Width="100"/>
                <DataGridTextColumn Header="Legierung" Binding="{Binding Legierung}" Width="100"/>
                <DataGridTextColumn Header="Form" Binding="{Binding Form}" Width="70"/>
                <DataGridTextColumn Header="Stärke" Binding="{Binding Staerke, StringFormat={}{0:0.0} mm}" Width="80"/>
                <DataGridTextColumn Header="Maß" Binding="{Binding Mass}" Width="120"/>
                <DataGridTextColumn Header="Stück" Binding="{Binding Stueckzahl}" Width="60"/>
                <DataGridTextColumn Header="Restnummer" Binding="{Binding Restnummer}" Width="120"/>
                <DataGridTextColumn Header="Lagerort" Binding="{Binding Lagerort}" Width="90"/>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="OK" Click="OnOk" Width="80"/>
            <Button Content="Abbrechen" Click="OnCancel" Width="100" Background="#555"/>
        </StackPanel>
    </DockPanel>
</Window>
