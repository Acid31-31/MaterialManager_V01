<Window x:Class="MaterialManager_V01.Views.UpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🔄 Updates verfügbar" Height="500" Width="700" Background="#0B0B0B" WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#1F1F1F" Padding="20">
            <StackPanel>
                <TextBlock Text="🔄 MaterialManager Update" FontSize="22" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Eine neue Version ist verfügbar!" Foreground="#4CAF50" FontSize="14" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>
        
        <Border DockPanel.Dock="Bottom" Background="#1F1F1F" Padding="15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Jetzt installieren" Click="OnInstallieren" Background="#4CAF50" Foreground="White" Padding="15,8" Margin="0,0,10,0" FontWeight="Bold"/>
                <Button Content="Später" Click="OnSpaeter" Background="#666" Foreground="White" Padding="15,8"/>
            </StackPanel>
        </Border>
        
        <ScrollViewer Margin="20" Background="#121212">
            <StackPanel>
                <Border Background="#1E1E1E" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Version" Foreground="#888" FontSize="12"/>
                        <TextBlock Text="{Binding VersionInfo}" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                
                <Border Background="#1E1E1E" CornerRadius="6" Padding="15">
                    <StackPanel>
                        <TextBlock Text="🎉 Neue Features:" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding Changelog}" Foreground="White" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
