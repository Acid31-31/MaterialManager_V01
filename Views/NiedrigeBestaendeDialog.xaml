<Window x:Class="MaterialManager_V01.Views.NiedrigeBestaendeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="⚠️ Niedrige Bestände - Übersicht"
        Height="700" Width="1000"
        WindowStartupLocation="CenterOwner"
        Background="#0B0B0B">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Margin" Value="0,4" />
        </Style>

        <Style x:Key="FilterComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#222" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#444" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton
                                Name="ToggleButton"
                                Grid.Column="2"
                                Focusable="false"
                                IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                ClickMode="Press"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            </ToggleButton>
                            <ContentPresenter
                                Name="ContentSite"
                                IsHitTestVisible="False"
                                Content="{TemplateBinding SelectionBoxItem}"
                                ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                Margin="3,3,23,3"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left">
                            </ContentPresenter>
                            <TextBox
                                x:Name="PART_EditableTextBox"
                                Visibility="Hidden"
                                IsReadOnly="{TemplateBinding IsReadOnly}"/>
                            <Popup
                                Name="Popup"
                                Placement="Bottom"
                                IsOpen="{TemplateBinding IsDropDownOpen}"
                                AllowsTransparency="True"
                                Focusable="False"
                                PopupAnimation="Slide">
                                <Grid
                                    Name="DropDown"
                                    SnapsToDevicePixels="True"
                                    MinWidth="{TemplateBinding ActualWidth}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border
                                        x:Name="DropDownBorder"
                                        Background="#222"
                                        BorderThickness="1"
                                        BorderBrush="#444">
                                        <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#222" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border
                            Name="Border"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1976D2" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#333" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#1976D2" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Margin" Value="8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="RowBackground" Value="#151515" />
            <Setter Property="AlternatingRowBackground" Value="#121212" />
            <Setter Property="GridLinesVisibility" Value="None" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="BorderBrush" Value="#222" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#121212" />
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="#151515" />
            <Setter Property="Foreground" Value="White" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Stueckzahl}" Value="1">
                    <Setter Property="Background" Value="#4D1616" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Stueckzahl}" Value="0">
                    <Setter Property="Background" Value="#661111" />
                </DataTrigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#252525" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1E1E1E" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="BorderBrush" Value="#333" />
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header mit Legende -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="⚠️ Materialien mit niedrigen Beständen" FontSize="18" FontWeight="Bold"/>
            <TextBlock Text="Nur Tafeln (GF, MF, KF) mit 3 oder weniger Stück" FontSize="12" Foreground="#888" Margin="0,4,0,8"/>
            
            <StackPanel Orientation="Horizontal">
                <Border Background="#661111" Width="20" Height="20" Margin="0,0,8,0"/>
                <TextBlock Text="0-1 Stück = Kritisch (Rot)" Margin="0,0,24,0" VerticalAlignment="Center"/>
                
                <Border Background="#4D1616" Width="20" Height="20" Margin="0,0,8,0"/>
                <TextBlock Text="2 Stück = Niedrig (Orange)" Margin="0,0,24,0" VerticalAlignment="Center"/>
                
                <Border Background="#333" Width="20" Height="20" Margin="0,0,8,0"/>
                <TextBlock Text="3 Stück = Warnung (Gelb)" VerticalAlignment="Center"/>
            </StackPanel>
        </StackPanel>

        <!-- Filter -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Filter:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,12,0"/>
            
            <ComboBox x:Name="MaterialFilterBox" Style="{StaticResource FilterComboBox}" Width="150" SelectionChanged="OnFilterChanged">
                <ComboBoxItem IsSelected="True">Alle Materialien</ComboBoxItem>
                <ComboBoxItem>Stahl</ComboBoxItem>
                <ComboBoxItem>Edelstahl</ComboBoxItem>
                <ComboBoxItem>Aluminium</ComboBoxItem>
            </ComboBox>

            <ComboBox x:Name="FormFilterBox" Style="{StaticResource FilterComboBox}" Width="120" SelectionChanged="OnFilterChanged">
                <ComboBoxItem IsSelected="True">Alle Formen</ComboBoxItem>
                <ComboBoxItem>GF</ComboBoxItem>
                <ComboBoxItem>MF</ComboBoxItem>
                <ComboBoxItem>KF</ComboBoxItem>
            </ComboBox>
        </StackPanel>

        <!-- DataGrid -->
        <DataGrid Grid.Row="2" x:Name="BestandGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  MouseDoubleClick="OnMaterialDoppelklick"
                  RowHeight="36">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Material" Binding="{Binding MaterialArt}" Width="120"/>
                <DataGridTextColumn Header="Legierung" Binding="{Binding Legierung}" Width="120"/>
                <DataGridTextColumn Header="Oberfläche" Binding="{Binding Oberflaeche}" Width="140"/>
                <DataGridTextColumn Header="Güte" Binding="{Binding Guete}" Width="100"/>
                <DataGridTextColumn Header="Form" Binding="{Binding Form}" Width="80"/>
                <DataGridTextColumn Header="Stärke" Binding="{Binding Staerke, StringFormat={}{0:0.0} mm}" Width="80"/>
                <DataGridTextColumn Header="Maß" Binding="{Binding Mass}" Width="120"/>
                <DataGridTextColumn Header="Stück" Binding="{Binding Stueckzahl}" Width="80">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Stueckzahl}" Value="0">
                                    <Setter Property="Foreground" Value="#F44336"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Stueckzahl}" Value="1">
                                    <Setter Property="Foreground" Value="#F44336"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Stueckzahl}" Value="2">
                                    <Setter Property="Foreground" Value="#FF9800"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Stueckzahl}" Value="3">
                                    <Setter Property="Foreground" Value="#FFC107"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Angelegt von" Binding="{Binding AngelegtVon}" Width="120"/>
                <DataGridTextColumn Header="Geändert von" Binding="{Binding GeaendertVon}" Width="120"/>
                <DataGridTextColumn Header="Lagerort" Binding="{Binding Lagerort}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="📄 Nachbestell-Liste exportieren" Click="OnExportNachbestellung" Width="240"/>
            <Button Content="Schließen" Click="OnSchliessen" Width="120" Background="#555"/>
        </StackPanel>
    </Grid>
</Window>
