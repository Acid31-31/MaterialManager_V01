<Window x:Class="MaterialManager_V01.Views.MaterialDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:MaterialManager_V01.Converters"
        Title="Material"
        Height="620" Width="420"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        KeyDown="OnKeyDown">

    <Window.Resources>
        <conv:StaerkeFormatConverter x:Key="StaerkeFormat"/>

        <!-- Dark theme for dialog -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#222" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#444" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton
                                Name="ToggleButton"
                                Grid.Column="2"
                                Focusable="false"
                                IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                ClickMode="Press"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            </ToggleButton>
                            <ContentPresenter
                                Name="ContentSite"
                                IsHitTestVisible="False"
                                Content="{TemplateBinding SelectionBoxItem}"
                                ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                Margin="3,3,23,3"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left">
                            </ContentPresenter>
                            <TextBox
                                x:Name="PART_EditableTextBox"
                                Visibility="Hidden"
                                IsReadOnly="{TemplateBinding IsReadOnly}"/>
                            <Popup
                                Name="Popup"
                                Placement="Bottom"
                                IsOpen="{TemplateBinding IsDropDownOpen}"
                                AllowsTransparency="True"
                                Focusable="False"
                                PopupAnimation="Slide">
                                <Grid
                                    Name="DropDown"
                                    SnapsToDevicePixels="True"
                                    MinWidth="{TemplateBinding ActualWidth}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border
                                        x:Name="DropDownBorder"
                                        Background="#222"
                                        BorderThickness="1"
                                        BorderBrush="#444">
                                        <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#222" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border
                            Name="Border"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1976D2" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#333" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#222" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#444" />
            <Setter Property="Padding" Value="4" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#1976D2" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Materialart:" VerticalAlignment="Center" Margin="0,5" />
        <ComboBox Grid.Row="0" Grid.Column="1"
                  ItemsSource="{Binding MaterialArten}"
                  SelectedItem="{Binding SelectedMaterialArt, Mode=TwoWay}"
                  Margin="0,5"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Legierung:" VerticalAlignment="Center" Margin="0,5" />
        <ComboBox Grid.Row="1" Grid.Column="1"
                  ItemsSource="{Binding Legierungen}"
                  SelectedItem="{Binding SelectedLegierung, Mode=TwoWay}"
                  Margin="0,5"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Oberfläche:" VerticalAlignment="Center" Margin="0,5" />
        <ComboBox Grid.Row="2" Grid.Column="1"
                  ItemsSource="{Binding Oberflaechen}"
                  SelectedItem="{Binding SelectedOberflaeche, Mode=TwoWay}"
                  Margin="0,5"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Güte:" VerticalAlignment="Center" Margin="0,5" Visibility="{Binding GueteVisible}" />
        <ComboBox Grid.Row="3" Grid.Column="1"
                  ItemsSource="{Binding Gueten}"
                  SelectedItem="{Binding SelectedGuete, Mode=TwoWay}"
                  Visibility="{Binding GueteVisible}"
                  Margin="0,5"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Form:" VerticalAlignment="Center" Margin="0,5" />
        <ComboBox Grid.Row="4" Grid.Column="1"
                  ItemsSource="{Binding Formen}"
                  SelectedItem="{Binding SelectedForm, Mode=TwoWay}"
                  Margin="0,5"/>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="Stärke (mm):" VerticalAlignment="Center" Margin="0,5" />
        <ComboBox Grid.Row="5" Grid.Column="1"
                  ItemsSource="{Binding Staerken}"
                  SelectedItem="{Binding SelectedStaerke, Mode=TwoWay}"
                  Margin="0,5">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Converter={StaticResource StaerkeFormat}}"/>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <TextBlock Grid.Row="6" Grid.Column="0" Text="Maß (LxB mm):" VerticalAlignment="Center" Margin="0,5" />
        <TextBox Grid.Row="6" Grid.Column="1"
                 Text="{Binding Mass, Mode=TwoWay}"
                 Margin="0,5"
                 IsEnabled="{Binding IsMassEditable}"/>

        <!-- Stückzahl - nur für GF, MF, KF sichtbar -->
        <TextBlock Grid.Row="7" Grid.Column="0" Text="Stückzahl:" VerticalAlignment="Center" Margin="0,5" 
                   Visibility="{Binding StueckzahlVisible}"/>
        <TextBox Grid.Row="7" Grid.Column="1"
                 Text="{Binding Stueckzahl, Mode=TwoWay}"
                 Margin="0,5"
                 Visibility="{Binding StueckzahlVisible}"/>

        <TextBlock Grid.Row="8" Grid.Column="0" Text="Restnummer:" VerticalAlignment="Center" Margin="0,5" />
        <TextBlock Grid.Row="8" Grid.Column="1"
                   Text="{Binding Restnummer}"
                   Margin="0,5"/>

        <!-- Lieferdatum - bei GF/MF/KF: Lieferdatum, bei Rest: Erstelldatum (nur Anzeige) -->
        <TextBlock Grid.Row="9" Grid.Column="0" Text="{Binding DatumLabel}" VerticalAlignment="Center" Margin="0,5" />
        <DatePicker Grid.Row="9" Grid.Column="1"
                    SelectedDate="{Binding SelectedDatum, Mode=TwoWay}"
                    Margin="0,5"
                    Background="#222" Foreground="White" BorderBrush="#444"/>

        <!-- Lieferant - nur bei Neuanlage GF/MF/KF -->
        <TextBlock Grid.Row="10" Grid.Column="0" Text="Lieferant:" VerticalAlignment="Center" Margin="0,5"
                   Visibility="{Binding LieferantVisible}"/>
        <TextBox Grid.Row="10" Grid.Column="1"
                 Text="{Binding SelectedLieferant, Mode=TwoWay}"
                 Margin="0,5"
                 Visibility="{Binding LieferantVisible}"/>

        <!-- Lieferschein-Nr - nur bei GF/MF/KF -->
        <TextBlock Grid.Row="11" Grid.Column="0" Text="Lieferschein-Nr:" VerticalAlignment="Center" Margin="0,5"
                   Visibility="{Binding LieferantVisible}"/>
        <TextBox Grid.Row="11" Grid.Column="1"
                 Text="{Binding SelectedLieferscheinNr, Mode=TwoWay}"
                 Margin="0,5"
                 Visibility="{Binding LieferantVisible}"/>

        <!-- Preis pro kg (NEU - Feature 8) -->
        <TextBlock Grid.Row="12" Grid.Column="0" Text="Preis (€/kg):" VerticalAlignment="Center" Margin="0,5"/>
        <StackPanel Grid.Row="12" Grid.Column="1" Orientation="Horizontal" Margin="0,5">
            <TextBox Text="{Binding PreisProKg, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Width="80"
                     Background="#222" Foreground="White" BorderBrush="#444" Padding="4"/>
            <TextBlock Text="€/kg" Foreground="#888" VerticalAlignment="Center" Margin="4,0,8,0"/>
            <TextBlock Text="{Binding GeschaetzterWert}" Foreground="#FFD700" FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Shelf utilization -->
        <TextBlock Grid.Row="13" Grid.Column="0" Text="Regal-Auslastung:" VerticalAlignment="Center" Margin="0,5" />
        <StackPanel Grid.Row="13" Grid.Column="1" Orientation="Horizontal" Margin="0,5">
            <TextBlock Text="{Binding CurrentLoadKg, StringFormat={}{0:N2} kg}" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock Text="/" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock Text="{Binding CapacityKg, StringFormat={}{0:N0} kg}" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock Text="(" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding UtilizationPercent, StringFormat={}{0:N0}%}" VerticalAlignment="Center"/>
            <TextBlock Text=")" VerticalAlignment="Center"/>
            <TextBlock Text="  " />
            <TextBlock Text="Gesamt: " VerticalAlignment="Center" Margin="8,0,2,0"/>
            <TextBlock Text="{Binding TotalInventoryWeight, StringFormat={}{0:N2} kg}" VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="14" Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,15,0,0">

            <Button Content="🏷️ Etikett"
                    Width="80"
                    Margin="5"
                    Click="OnEtikett"
                    Visibility="{Binding EtikettVisible}"
                    Background="#795548"/>

            <Button Content="OK (Enter)"
                    Width="100"
                    Margin="5"
                    Click="OnOk"
                    IsDefault="True"
                    IsEnabled="{Binding CanSave}"/>

            <Button Content="Abbrechen"
                    Width="80"
                    Margin="5"
                    Click="OnCancel"
                    IsCancel="True"/>
        </StackPanel>

    </Grid>
</Window>
