<Window x:Class="MaterialManager_V01.Views.PrintDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Druck-Optionen" 
        Height="300" 
        Width="450"
        Background="#0B0B0B"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Background="#0B0B0B">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">
            <TextBlock Text="📄 Druck-Optionen" 
                       Foreground="White" 
                       FontSize="20" 
                       FontWeight="Bold" 
                       Margin="0,0,0,20"/>
            
            <Button Content="📊 Bestandsliste drucken" 
                    Click="OnPrintBestand"
                    Background="#1976D2" 
                    Foreground="White" 
                    Padding="15,15" 
                    Height="50"
                    FontSize="14"
                    Margin="0,0,0,10"
                    Cursor="Hand"/>
            
            <Button Content="📈 Lagerauslastung drucken" 
                    Click="OnPrintLagerAuslastung"
                    Background="#4CAF50" 
                    Foreground="White" 
                    Padding="15,15" 
                    Height="50"
                    FontSize="14"
                    Margin="0,0,0,10"
                    Cursor="Hand"/>
            
            <Button Content="📋 Audit-Log drucken" 
                    Click="OnPrintAuditLog"
                    Background="#FF9800" 
                    Foreground="White" 
                    Padding="15,15" 
                    Height="50"
                    FontSize="14"
                    Margin="0,0,0,10"
                    Cursor="Hand"/>
            
            <Button Content="❌ Abbrechen" 
                    Click="OnCancel"
                    Background="#333" 
                    Foreground="White" 
                    Padding="15,10" 
                    Height="40"
                    FontSize="12"/>
        </StackPanel>
    </Grid>
</Window>
