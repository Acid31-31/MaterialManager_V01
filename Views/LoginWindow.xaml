<Window x:Class="MaterialManager_V01.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MaterialManager V01 - Login" 
        Height="350" 
        Width="500"
        Background="#0B0B0B"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Icon="/Assets/logo.png">
    <Grid Background="#0B0B0B">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">
            <!-- LOGO -->
            <Image Source="/Assets/logo.png" Height="60" Margin="0,0,0,20"/>
            
            <!-- TITEL -->
            <TextBlock Text="MaterialManager V01" 
                       Foreground="White" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center"
                       Margin="0,0,0,5"/>
            
            <TextBlock Text="Professional Bestandsverwaltung" 
                       Foreground="#AAA" 
                       FontSize="12" 
                       HorizontalAlignment="Center"
                       Margin="0,0,0,25"/>
            
            <!-- USERNAME -->
            <TextBlock Text="Benutzername" Foreground="White" FontSize="12" Margin="0,0,0,5"/>
            <TextBox x:Name="UsernameTextBox" 
                     Background="#222" 
                     Foreground="White" 
                     Padding="10,8" 
                     Height="40"
                     FontSize="14"
                     Margin="0,0,0,15"/>
            
            <!-- PASSWORD -->
            <TextBlock Text="Passwort" Foreground="White" FontSize="12" Margin="0,0,0,5"/>
            <PasswordBox x:Name="PasswordBox" 
                         Background="#222" 
                         Foreground="White" 
                         Padding="10,8" 
                         Height="40"
                         FontSize="14"
                         Margin="0,0,0,20"/>
            
            <!-- ERROR MESSAGE -->
            <TextBlock x:Name="ErrorMessage" 
                       Text="" 
                       Foreground="#F44336" 
                       FontSize="12" 
                       Margin="0,0,0,15"
                       TextWrapping="Wrap"/>
            
            <!-- LOGIN BUTTON -->
            <Button Content="🔓 Anmelden" 
                    Click="OnLoginClick"
                    Background="#1976D2" 
                    Foreground="White" 
                    Padding="10,12" 
                    Height="45"
                    FontSize="14"
                    FontWeight="Bold"
                    Cursor="Hand"/>
            
            <!-- INFO -->
            <TextBlock Text="Demo-Accounts:" 
                       Foreground="#666" 
                       FontSize="11" 
                       Margin="0,20,0,5"/>
            
            <TextBlock Foreground="#555" FontSize="10" Margin="0,0,0,2">
                👤 admin / admin123  (Admin)
            </TextBlock>
            <TextBlock Foreground="#555" FontSize="10" Margin="0,0,0,2">
                👤 manager / manager123  (Manager)
            </TextBlock>
            <TextBlock Foreground="#555" FontSize="10">
                👤 lager / lager123  (Lagerarbeiter)
            </TextBlock>
        </StackPanel>
    </Grid>
</Window>
