<Window x:Class="MaterialManager_V01.Views.LicenseActivationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lizenz aktivieren - MaterialManager V01" 
        Height="1050" Width="1330" 
        WindowStartupLocation="CenterScreen"
        Background="#0B0B0B"
        ResizeMode="NoResize">
    
    <Border Padding="20" Background="#121212">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="🔑 Lizenzaktivierung" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Foreground="#4CAF50"
                           Margin="0,0,0,10"/>
                <TextBlock Text="Aktivieren Sie Ihre Vollversion von MaterialManager V01" 
                           FontSize="14" 
                           Foreground="#AAA"/>
                
                <!-- ⭐ BEWERTUNG & PREIS HINZUFÜGEN -->
                <Grid Margin="0,15,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Bewertung (Sterne) -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="⭐⭐⭐⭐⭐" FontSize="18" Foreground="#FFD700" Margin="0,0,8,0"/>
                        <TextBlock Text="4.9 / 5.0 (247 Bewertungen)" Foreground="#4CAF50" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <!-- Preis -->
                    <TextBlock Grid.Column="1" Text="ab 99€/Jahr" FontSize="16" FontWeight="Bold" Foreground="#FF9800" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
                
                <Border Background="#1E1E1E" 
                        CornerRadius="5" 
                        Padding="15" 
                        Margin="0,15,0,0">
                    <StackPanel>
                        <TextBlock Text="© 2025 Alexander Hölzer - Alle Rechte vorbehalten" 
                                   Foreground="White" 
                                   FontWeight="Bold"
                                   TextAlignment="Center"/>
                        <TextBlock Text="Urheberrechtlich geschützt gemäß §§ 69a ff. UrhG" 
                                   Foreground="#888" 
                                   FontSize="11"
                                   TextAlignment="Center"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Hardware-ID Anzeige -->
                    <Border Background="#1E1E1E" 
                            CornerRadius="5" 
                            Padding="15" 
                            Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="1️⃣ Ihre Hardware-ID" 
                                       FontSize="16" 
                                       FontWeight="Bold" 
                                       Foreground="White"
                                       Margin="0,0,0,10"/>
                            <TextBlock Text="Geben Sie diese ID beim Lizenzkauf an:" 
                                       Foreground="#AAA" 
                                       FontSize="12"
                                       Margin="0,0,0,8"/>
                            <Border Background="#0F0F0F" 
                                    BorderBrush="#333" 
                                    BorderThickness="1"
                                    CornerRadius="3"
                                    Padding="10">
                                <Grid>
                                    <TextBox x:Name="HardwareIdTextBox"
                                             Text="{Binding HardwareId, Mode=OneWay}"
                                             IsReadOnly="True"
                                             Background="Transparent"
                                             Foreground="#4CAF50"
                                             BorderThickness="0"
                                             FontFamily="Consolas"
                                             FontSize="14"
                                             FontWeight="Bold"/>
                                    <Button Content="📋 Kopieren"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Background="#333"
                                            Foreground="White"
                                            Padding="10,5"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Click="OnCopyHardwareId"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Lizenzschlüssel Eingabe -->
                    <Border Background="#1E1E1E" 
                            CornerRadius="5" 
                            Padding="15" 
                            Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="2️⃣ Lizenzschlüssel eingeben" 
                                       FontSize="16" 
                                       FontWeight="Bold" 
                                       Foreground="White"
                                       Margin="0,0,0,10"/>
                            <TextBlock Text="Format: XXXX-XXXX-XXXX-XXXX" 
                                       Foreground="#AAA" 
                                       FontSize="12"
                                       Margin="0,0,0,8"/>
                            <TextBox x:Name="LicenseKeyTextBox"
                                     Background="#0F0F0F"
                                     Foreground="White"
                                     Padding="10"
                                     FontFamily="Consolas"
                                     FontSize="14"
                                     BorderBrush="#333"
                                     BorderThickness="1"
                                     MaxLength="19"
                                     TextChanged="OnLicenseKeyChanged"/>
                        </StackPanel>
                    </Border>

                    <!-- Registrierung -->
                    <Border Background="#1E1E1E" 
                            CornerRadius="5" 
                            Padding="15" 
                            Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="3️⃣ Registrierungsinformationen" 
                                       FontSize="16" 
                                       FontWeight="Bold" 
                                       Foreground="White"
                                       Margin="0,0,0,10"/>
                            <TextBlock Text="Firma / Name:" 
                                       Foreground="#AAA" 
                                       FontSize="12"
                                       Margin="0,0,0,5"/>
                            <TextBox x:Name="RegisteredToTextBox"
                                     Background="#0F0F0F"
                                     Foreground="White"
                                     Padding="10"
                                     FontSize="13"
                                     BorderBrush="#333"
                                     BorderThickness="1"
                                     MaxLength="100"/>
                        </StackPanel>
                    </Border>

                    <!-- Lizenztyp-Info mit PREISEN -->
                    <Border Background="#1F1F1F" 
                            BorderBrush="#4CAF50" 
                            BorderThickness="2"
                            CornerRadius="5" 
                            Padding="15" 
                            Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="💰 Verfügbare Lizenztypen und Preise" 
                                       FontSize="14" 
                                       FontWeight="Bold" 
                                       Foreground="#4CAF50"
                                       Margin="0,0,0,12"/>
                            
                            <!-- Single Lizenz -->
                            <Border Background="#2A2A2A" CornerRadius="3" Padding="12" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="🔹 Single (S1)" FontWeight="Bold" Foreground="White" FontSize="12"/>
                                        <TextBlock Text="1 Arbeitsplatz" Foreground="#AAA" FontSize="11" Margin="0,3,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                        <TextBlock Text="99,00 EUR" FontWeight="Bold" Foreground="#4CAF50" FontSize="13"/>
                                        <TextBlock Text="/Jahr" Foreground="#888" FontSize="10" HorizontalAlignment="Right"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            
                            <!-- Mehrplatz Lizenz -->
                            <Border Background="#2A2A2A" CornerRadius="3" Padding="12" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="🔹 Mehrplatz (M3)" FontWeight="Bold" Foreground="White" FontSize="12"/>
                                        <TextBlock Text="3 Arbeitsplätze" Foreground="#AAA" FontSize="11" Margin="0,3,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                        <TextBlock Text="249,00 EUR" FontWeight="Bold" Foreground="#FF9800" FontSize="13"/>
                                        <TextBlock Text="/Jahr" Foreground="#888" FontSize="10" HorizontalAlignment="Right"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            
                            <!-- Firmen Lizenz -->
                            <Border Background="#2A2A2A" CornerRadius="3" Padding="12" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="🔹 Firmenlizenz (C10)" FontWeight="Bold" Foreground="White" FontSize="12"/>
                                        <TextBlock Text="10 Arbeitsplätze + Support" Foreground="#AAA" FontSize="11" Margin="0,3,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                        <TextBlock Text="699,00 EUR" FontWeight="Bold" Foreground="#F44336" FontSize="13"/>
                                        <TextBlock Text="/Jahr" Foreground="#888" FontSize="10" HorizontalAlignment="Right"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            
                            <!-- Enterprise -->
                            <Border Background="#2A2A2A" CornerRadius="3" Padding="12" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="🔹 Enterprise (ENT)" FontWeight="Bold" Foreground="White" FontSize="12"/>
                                        <TextBlock Text="Unbegrenzte Arbeitsplätze + Support" Foreground="#AAA" FontSize="11" Margin="0,3,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                        <TextBlock Text="Auf Anfrage" FontWeight="Bold" Foreground="#2196F3" FontSize="13"/>
                                        <TextBlock Text="Individuell" Foreground="#888" FontSize="10" HorizontalAlignment="Right"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            
                            <!-- Hinweis -->
                            <TextBlock Text="ℹ️ 30 Tage kostenlose Testversion. Keine Kreditkarte erforderlich!" 
                                       Foreground="#4CAF50" 
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Margin="0,10,0,0"
                                       TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Kontakt & Support -->
                    <Border Background="#1E1E1E" 
                            BorderBrush="#2196F3"
                            BorderThickness="1"
                            CornerRadius="5" 
                            Padding="15" 
                            Margin="0,0,0,0">
                        <StackPanel>
                            <TextBlock Text="📞 Kontakt und Support" 
                                       FontSize="13" 
                                       FontWeight="Bold" 
                                       Foreground="#2196F3"
                                       Margin="0,0,0,10"/>
                            

                            <TextBlock Foreground="#4CAF50" FontWeight="Bold" Margin="0,3,0,0">
                                <Run Text="✉️ E-Mail: "/>
                                <Run Text="hoelzer_alex@yahoo.de"/>
                            </TextBlock>
                            
                            <TextBlock Foreground="#4CAF50" FontWeight="Bold" Margin="0,3,0,0">
                                <Run Text="📱 Telefon: "/>
                                <Run Text="+49 170 8339993"/>
                            </TextBlock>
                            
                            <TextBlock Foreground="#AAA" FontSize="10" Margin="0,8,0,0" TextWrapping="Wrap">
                                Nach Zahlungseingang erhalten Sie sofort Ihren persönlichen Lizenzschlüssel per E-Mail. Support inklusive!
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Right"
                        Margin="0,20,0,0">
                <Button Content="❌ Abbrechen" 
                        Click="OnCancel"
                        Background="#444" 
                        Foreground="White"
                        Padding="20,10"
                        Margin="0,0,10,0"
                        BorderThickness="0"
                        Cursor="Hand"
                        FontSize="13"
                        FontWeight="Bold">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#444"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                                CornerRadius="3"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#555"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                
                <Button x:Name="ActivateButton"
                        Content="✓ Lizenz aktivieren" 
                        Click="OnActivate"
                        Background="#4CAF50" 
                        Foreground="White"
                        Padding="20,10"
                        BorderThickness="0"
                        Cursor="Hand"
                        IsEnabled="False"
                        FontSize="13"
                        FontWeight="Bold">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                                CornerRadius="3"
                                                Padding="{TemplateBinding Padding}">
                                            <TextBlock Text="{TemplateBinding Content}" 
                                                       HorizontalAlignment="Center" 
                                                       VerticalAlignment="Center"
                                                       Foreground="{TemplateBinding Foreground}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#666"/>
                                    <Setter Property="Foreground" Value="#CCC"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="True">
                                    <Setter Property="Background" Value="#4CAF50"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#45a049"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
