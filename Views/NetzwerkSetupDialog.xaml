<Window x:Class="MaterialManager_V01.Views.NetzwerkSetupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🌐 Netzwerk-Synchronisation einrichten" Height="450" Width="700" Background="#0B0B0B" WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="🔄 Multi-PC Synchronisation" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

        <Border Grid.Row="1" Background="#1E1E1E" Padding="15" CornerRadius="5" Margin="0,0,0,20">
            <StackPanel>
                <CheckBox x:Name="NetzwerkModeCheckBox" Content="Netzwerk-Modus aktivieren" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,0,0,15"/>
                
                <TextBlock Text="Netzwerkpfad (z.B. \\SERVER\MaterialManager oder Z:\MaterialManager):" Foreground="White" FontSize="12" Margin="0,0,0,5"/>
                
                <DockPanel Margin="0,0,0,10">
                    <Button DockPanel.Dock="Right" Content="📁 Durchsuchen" Click="OnDurchsuchen" Width="120" Background="#1976D2" Foreground="White" Padding="8" Margin="5,0,0,0" Cursor="Hand"/>
                    <TextBox x:Name="NetzwerkPfadBox" Background="#222" Foreground="White" Padding="8" Height="32" VerticalContentAlignment="Center"/>
                </DockPanel>

                <TextBlock Text="💡 Tipp: Verwenden Sie ein Netzlaufwerk (Z:) für bessere Performance!" Foreground="#FFA500" FontSize="11" FontStyle="Italic" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="#1E1E1E" Padding="15" CornerRadius="5">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="📋 So funktioniert's:" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                    
                    <TextBlock Foreground="#AAA" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,10">
                        <Run Text="1. Erstellen Sie einen gemeinsamen Ordner auf Ihrem Server oder einem PC"/>
                        <LineBreak/>
                        <Run Text="2. Teilen Sie diesen Ordner im Netzwerk (Vollzugriff für alle User)"/>
                        <LineBreak/>
                        <Run Text="3. Verbinden Sie den Ordner als Netzlaufwerk (Z:) auf allen PCs"/>
                        <LineBreak/>
                        <Run Text="4. Geben Sie hier den Pfad ein (z.B. Z:\MaterialManager)"/>
                        <LineBreak/>
                        <Run Text="5. Aktivieren Sie den Netzwerk-Modus"/>
                        <LineBreak/>
                        <Run Text="6. Starten Sie die App auf allen PCs neu"/>
                    </TextBlock>

                    <Border Background="#2A2A2A" Padding="10" CornerRadius="3" Margin="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="✅ Vorteile:" Foreground="#4CAF50" FontSize="12" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBlock Foreground="#AAA" FontSize="11" TextWrapping="Wrap">
                                <Run Text="• Echtzeit-Synchronisation zwischen allen PCs"/>
                                <LineBreak/>
                                <Run Text="• Änderungen werden sofort auf allen Geräten angezeigt"/>
                                <LineBreak/>
                                <Run Text="• Automatische Konflikt-Vermeidung"/>
                                <LineBreak/>
                                <Run Text="• Zentrale Datensicherung"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="💾 Speichern" Click="OnSpeichern" Width="120" Background="#4CAF50" Foreground="White" Padding="10,8" Margin="0,0,10,0" Cursor="Hand" FontWeight="Bold"/>
            <Button Content="Abbrechen" Click="OnAbbrechen" Width="120" Background="#555" Foreground="White" Padding="10,8" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
